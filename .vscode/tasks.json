{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Hope File",
      "type": "shell",
      "command": "hope",
      "args": ["-f", "${file}"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": true
      },
      "problemMatcher": [],
      "detail": "Execute the current Hope file"
    },
    {
      "label": "Run Hope Interactive",
      "type": "shell",
      "command": "hope",
      "args": [],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared"
      },
      "problemMatcher": [],
      "detail": "Start Hope interactive interpreter"
    },
    {
      "label": "Check Hope Syntax",
      "type": "shell",
      "command": "hope",
      "args": ["-f", "${file}"],
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "silent",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": {
        "owner": "hope",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^(.*):(\\d+):\\s+(.*error.*)$",
          "file": 1,
          "line": 2,
          "message": 3
        }
      },
      "detail": "Check syntax of the current Hope file"
    }
  ]
}
